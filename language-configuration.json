{
    "comments": {
        "lineComment": "//",
        "blockComment": [ "(*", "*)"]
    },
    "brackets": [
        ["Begin", "End"],
        ["{", "}"],
        ["[", "]"],
        ["(*", "*)"],
        ["(.", ".)"],
        ["(", ")"]
    ],
    "autoClosingPairs": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"],
        ["(.", "."],
        ["(*", "*"],
        {"open": "'", "close": "'", "notIn": ["string", "comment"]}
    ],
    "autoCloseBefore": ";:.,=}])>` \n\t",
    "surroundingPairs": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"],
        ["*", "*"],
        [".", "."],
        ["'", "'"]
    ],
    "wordPattern": "(?i:([_a-z][0-9_a-z]*))"
}
